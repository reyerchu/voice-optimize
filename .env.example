# PostgreSQL 連線（Session / Project / Export）
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:54321/voice_edit_db?schema=public"

# 內部 S2T（Whisper）轉錄服務
S2T_URL="http://192.168.1.120:8002"

# 上傳與匯出儲存路徑（本機磁碟）
UPLOAD_DIR="/home/reyerchu/voice-optimize/uploads"
EXPORT_DIR="/home/reyerchu/voice-optimize/exports"

# 上傳大小上限（bytes）— 500MB
MAX_UPLOAD_BYTES=524288000

# 對外公開網址
NEXT_PUBLIC_BASE_URL="https://voice-optimize.will.guide"
